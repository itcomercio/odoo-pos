# USB thermal printer udev rules (Zebra, Star, etc.)
# Ensure /dev/usb/lp* devices are created with appropriate permissions

# Generic USB printer rule (Vendor ID 0416 = Zebra, and others)
# This rule matches the USB printer class and ensures the device is accessible
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", \
  ATTRS{bDeviceClass}=="07", ATTRS{bDeviceSubClass}=="01", \
  MODE="0666", GROUP="lpadmin"

# Alternative: Match by specific Vendor ID (0416 = Zebra thermal printers)
# Uncomment if you want to be more specific to thermal printers
# SUBSYSTEM=="usb", ATTRS{idVendor}=="0416", ATTRS{idProduct}=="5011", \
#   MODE="0666", GROUP="lpadmin"

# usblp kernel module creates /dev/usb/lp* for printer class devices
SUBSYSTEM=="usb", KERNEL=="lp[0-9]*", \
  MODE="0666", GROUP="lpadmin"

# Alternative usblp interface rule (redundant but safer)
SUBSYSTEM=="printer", KERNEL=="lp[0-9]*", \
  MODE="0666", GROUP="lpadmin"

