# Odoo container image reference.
# You can pin a digest for fully deterministic updates:
# ODOO_CONTAINER_IMAGE=localhost/odoo-pos@sha256:...
ODOO_CONTAINER_IMAGE=localhost/odoo-pos:19.0

# Container name managed by systemd scripts.
ODOO_CONTAINER_NAME=odoo

# Increase Odoo request real-time limit for low-power CPUs during heavy module
# initialization (e.g. POS first load). Equivalent to --limit-time-real.
ODOO_LIMIT_TIME_REAL=900

